generator client {
  provider = "prisma-client-js"
}

// Porcentajes almacenados como basis points (bp) — enteros, sin float
// 7000 bp = 70.00%  |  500 bp = 5.00%  |  399 bp = 3.99%
// Montos siempre en centavos (Int). $ 10,00 ARS = 1000 centavos.

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  VENDEDOR
}

enum TipoMovimientoStock {
  ENTRADA
  SALIDA
  AJUSTE
}

enum EstadoPago {
  TRIAL     // periodo de prueba, sin tarjeta
  ACTIVO    // suscripción de Mercado Pago autorizada y al día
  VENCIDO   // trial terminado sin suscripción, o suscripción pausada/con pago rechazado
  CANCELADO // el usuario canceló la suscripción
}

// ─── Tenant ─────────────────────────────────────────────────────────────────

model Organization {
  id                      String     @id @default(cuid())
  nombre                  String
  cuit                    String?
  puntoDeVenta            Int?
  condicionIva            String?    // validado vía Zod: RESPONSABLE_INSCRIPTO | MONOTRIBUTO | EXENTO | CONSUMIDOR_FINAL
  // false = homologación (comprobantes de prueba, sin validez fiscal), true = producción
  // real (CAE real, no anulable). Ver facturacionService.facturarVenta.
  facturacionModoProduccion Boolean  @default(false)
  // Si true, cada venta manda un tiquet a la terminal Point marcada como
  // posnet (PaymentMethod.mpTerminalId) vía la API de Terminals de MercadoPago
  // — no requiere que la venta se haya pagado con esa terminal. Ver impresionService.
  imprimirTicketPosnet    Boolean    @default(false)
  stockMinimoDefault      Int        @default(0)
  onboardingCompletadoAt  DateTime?  // null = primer inicio sin completar
  // Saldo real en la cuenta de Mercado Pago, cargado a mano (no hay API de saldo
  // disponible para esta integración) — se usa en el equilibrio de Inicio.
  saldoMpCentavos         Int?
  saldoMpActualizadoEn    DateTime?
  // ── Suscripción (paywall del SaaS, no confundir con los cobros del kiosco a SUS clientes) ──
  estadoPago              EstadoPago @default(TRIAL)
  trialTerminaEl          DateTime?  // seteado al completar el onboarding = ahora + 14 días
  mpPreapprovalId         String?    // id de la suscripción en Mercado Pago una vez autorizada
  // Horarios de arqueo parcial ("HH:mm,HH:mm", ej. "14:00,19:00") — conteos de
  // control durante el día que NO cierran la caja, para detectar diferencias
  // antes de que se acumulen muchas horas. Null = usa el default de la app.
  horariosArqueo          String?
  createdAt               DateTime   @default(now())
  updatedAt               DateTime   @updatedAt

  users           User[]
  categories      Category[]
  providers       Provider[]
  locations       Location[]
  products        Product[]
  sales           Sale[]
  paymentMethods  PaymentMethod[]
  fixedExpenses   FixedExpense[]
  cajas           Caja[]
  cajaSesiones    CajaSesion[]
  movimientosCaja MovimientoCaja[]
  arqueosParciales ArqueoParcial[]
  customers       Customer[]
  comprobantes    Comprobante[]
  movimientosCuentaCorrienteProveedor MovimientoCuentaCorrienteProveedor[]
}

// ─── Usuarios ────────────────────────────────────────────────────────────────

model User {
  id                  String       @id @default(cuid())
  email               String?      @unique // null en perfiles de empleado (solo nombre+PIN, sin login propio)
  passwordHash        String?      // null si el usuario solo se loguea con Google, o es un perfil PIN-only
  pinHash             String?      // PIN corto (4 dígitos) para el cambio rápido de perfil en el kiosco
  image               String?      // foto de perfil de Google, opcional
  nombre              String
  role                Role         @default(VENDEDOR)
  activo              Boolean      @default(true)
  failedLoginAttempts Int          @default(0) // se resetea en cada login/PIN exitoso — comparte umbral entre password y PIN
  lockedUntil         DateTime?    // bloqueo temporal por fuerza bruta de contraseña o PIN
  organizationId      String
  organization        Organization @relation(fields: [organizationId], references: [id])
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  sales            Sale[]
  stockMovements   StockMovement[]
  sesionesAbiertas CajaSesion[] @relation("SesionAbiertaPor")
  sesionesCerradas CajaSesion[] @relation("SesionCerradaPor")
  arqueosParciales ArqueoParcial[]
}

// ─── Configuración ──────────────────────────────────────────────────────────

model Category {
  id              String       @id @default(cuid())
  nombre          String
  markupDefaultBp Int          // 7000 = 70.00%, 500 = 5.00% — usado cuando markupDefaultTipo = "PORCENTUAL"
  markupDefaultTipo          String @default("PORCENTUAL") // "PORCENTUAL" | "FIJO" — validado Zod
  markupDefaultFijoCentavos  Int    @default(0)            // ganancia fija default (centavos) — usado cuando markupDefaultTipo = "FIJO"
  activo          Boolean      @default(true)
  cajaId          String?      // null = usa la caja principal de la org
  caja            Caja?        @relation(fields: [cajaId], references: [id])
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  products Product[]

  @@unique([nombre, organizationId])
}

model Provider {
  id             String       @id @default(cuid())
  nombre         String
  activo         Boolean      @default(true)
  // Fondo de reposición: se acumula con cada venta (100% del costo + 60% de la
  // ganancia de las líneas cuando este proveedor tiene algún producto en stock bajo)
  // y se descuenta cuando se registra una ENTRADA de stock (compra real al proveedor).
  // Puede ir negativo si se compró más de lo que el fondo cubría — es informativo,
  // no un límite duro.
  saldoReposicionCentavos Int @default(0)
  // Cuenta corriente: cuánto le debemos a este proveedor. Sube al registrar una
  // compra a crédito, baja al registrar un pago (que además crea un EGRESO real
  // en la caja elegida). Puede ir negativo si se pagó de más — informativo. El
  // saldo vive acá (rápido de leer); el detalle de cada movimiento está en
  // MovimientoCuentaCorrienteProveedor.
  saldoCuentaCorrienteCentavos Int @default(0)
  // Piso de reinversión: colchón en pesos que SIEMPRE debe quedar reservado
  // para reponerle stock a este proveedor antes de considerar "ganancia
  // limpia" disponible — ver resumenService.reparto. A diferencia de
  // saldoReposicionCentavos (que se acumula solo con las ventas), este es un
  // monto fijo que carga el dueño a mano y NO se resetea cada mes: una vez
  // alcanzado, deja de restar hasta que se gaste comprando stock.
  pisoReposicionCentavos Int @default(0)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  products Product[]
  movimientosCuentaCorriente MovimientoCuentaCorrienteProveedor[]

  @@unique([nombre, organizationId])
}

/**
 * Ledger de cuenta corriente de un proveedor — una fila por cada compra a
 * crédito o pago (ver proveedorService.registrarCompraCuentaCorriente /
 * registrarPagoCuentaCorriente), sea que haya pasado por
 * pedidoProveedorService.ingresar o se haya cargado a mano. Solo es
 * historial: el saldo vigente sigue viviendo en
 * Provider.saldoCuentaCorrienteCentavos (más rápido de leer que sumar filas).
 */
model MovimientoCuentaCorrienteProveedor {
  id             String       @id @default(cuid())
  providerId     String
  provider       Provider     @relation(fields: [providerId], references: [id])
  tipo           String       // "COMPRA" | "PAGO" — validado Zod
  montoCentavos  Int
  // Solo en PAGO — de qué caja salió la plata (crea además un EGRESO real ahí).
  cajaId         String?
  caja           Caja?        @relation(fields: [cajaId], references: [id])
  nota           String?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
}

model Customer {
  id             String       @id @default(cuid())
  nombre         String
  telefono       String?
  direccion      String?
  activo         Boolean      @default(true)
  // Cuenta corriente: cuánto nos debe este cliente (inverso de
  // Provider.saldoCuentaCorrienteCentavos). Sube al dejar un resto fiado en
  // una venta (Sale.fiadoCentavos), baja al registrar un pago de deuda (que
  // además crea un INGRESO real en la caja elegida) — ver customerService.
  saldoCuentaCorrienteCentavos Int @default(0)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  sales Sale[]

  @@unique([nombre, organizationId])
}

model Location {
  id             String       @id @default(cuid())
  nombre         String
  activo         Boolean      @default(true)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  products Product[]

  @@unique([nombre, organizationId])
}

model PaymentMethod {
  id             String       @id @default(cuid())
  nombre         String
  comisionBp     Int          @default(0) // 399 = 3.99%
  esMercadoPago  Boolean      @default(false)
  esEfectivo     Boolean      @default(false) // true = efectivo de caja; false = virtual (no suma al arqueo)
  activo         Boolean      @default(true)
  esDefault      Boolean      @default(false) // único por org — POS lo preselecciona
  orden          Int          @default(0)     // define orden en el POS
  cajaId         String?      // si está seteado, las ventas con este medio van enteras a esta caja (override del split por categoría)
  caja           Caja?        @relation(fields: [cajaId], references: [id])
  mpExternalPosId String?     // external_pos_id del QR físico de MercadoPago (solo si esMercadoPago = true)
  mpTerminalId    String?     // terminal_id del posnet Point de MercadoPago (solo si esMercadoPago = true)
  // Recargo por pago virtual — se configura UNA vez por medio de pago, no por caja.
  recargoTipo                String @default("PORCENTUAL") // "PORCENTUAL" | "FIJO" — validado Zod
  recargoVirtualBp           Int    @default(0)             // recargo % si el medio no es efectivo (0 = sin recargo)
  recargoVirtualFijoCentavos Int    @default(0)             // recargo $ fijo si el medio no es efectivo
  // Si una venta se cobra (total o parcialmente) con este medio, se factura
  // automáticamente por AFIP al confirmarla — ver facturacionService.facturarVenta.
  // Default true al crear un medio con esMercadoPago=true (ver medioPagoService.crear).
  facturarAutomaticamente Boolean @default(false)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  payments        Payment[]
  movimientosCaja MovimientoCaja[]

  @@unique([nombre, organizationId])
}

model FixedExpense {
  id             String       @id @default(cuid())
  nombre         String
  activo         Boolean      @default(true)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  montos      FixedExpenseMonto[]
  movimientos MovimientoCaja[]

  @@unique([nombre, organizationId])
}

model FixedExpenseMonto {
  id             String       @id @default(cuid())
  fixedExpenseId String
  fixedExpense   FixedExpense @relation(fields: [fixedExpenseId], references: [id], onDelete: Cascade)
  mesAnio        String       // "YYYY-MM", ej. "2026-06"
  montoCentavos  Int
  createdAt      DateTime     @default(now())

  @@unique([fixedExpenseId, mesAnio])
}

// ─── Cajas ───────────────────────────────────────────────────────────────────

model Caja {
  id                       String       @id @default(cuid())
  nombre                   String
  esPrincipal              Boolean      @default(false) // "Caja general" — una por org, no borrable
  manejaEfectivo           Boolean      @default(true)  // false = caja 100% digital (ej. MercadoPago/QR) — no exige cierre al cambiar de perfil
  orden                    Int          @default(0)
  activo                   Boolean      @default(true)
  // Saldo real contado a mano (efectivo físico), para el equilibrio de Inicio —
  // independiente del efectivo esperado calculado por movimientos de la sesión abierta.
  saldoManualCentavos      Int?
  saldoManualActualizadoEn DateTime?
  organizationId           String
  organization             Organization @relation(fields: [organizationId], references: [id])
  createdAt                DateTime     @default(now())
  updatedAt                DateTime     @updatedAt

  categories     Category[]
  sesiones       CajaSesion[]
  movimientos    MovimientoCaja[]
  mediosDePago   PaymentMethod[]
  arqueosParciales ArqueoParcial[]
  movimientosCuentaCorrienteProveedor MovimientoCuentaCorrienteProveedor[]

  @@unique([nombre, organizationId])
}

model CajaSesion {
  id                       String    @id @default(cuid())
  cajaId                   String
  caja                     Caja      @relation(fields: [cajaId], references: [id])
  abiertaPorUserId         String
  abiertaPor               User      @relation("SesionAbiertaPor", fields: [abiertaPorUserId], references: [id])
  cerradaPorUserId         String?
  cerradaPor               User?     @relation("SesionCerradaPor", fields: [cerradaPorUserId], references: [id])
  fondoInicialCentavos     Int
  fechaApertura            DateTime  @default(now())
  fechaCierre              DateTime?
  efectivoEsperadoCentavos Int?      // calculado al cerrar
  efectivoContadoCentavos  Int?      // ingresado por el usuario al cerrar
  diferenciaCentavos       Int?      // = contado − esperado
  nota                     String?   // observación opcional al cerrar (ej. explicar diferencia)
  estado                   String    // "ABIERTA" | "CERRADA" — validado Zod
  organizationId           String
  organization             Organization @relation(fields: [organizationId], references: [id])

  movimientos MovimientoCaja[]
  arqueosParciales ArqueoParcial[]
}

/**
 * Conteo de control en un horario fijo (ej. 14:00, 19:00) DENTRO de una
 * sesión de caja abierta — a diferencia del cierre, no termina la sesión ni
 * cambia su fondo/estado, solo deja constancia de esperado/contado/diferencia
 * en ese momento. Pensado para detectar diferencias temprano en vez de
 * arrastrarlas horas o días (ver el desfasaje real de Mercado Pago del
 * 2026-07-10 que este feature busca evitar a futuro).
 */
model ArqueoParcial {
  id                       String     @id @default(cuid())
  cajaSesionId             String
  cajaSesion               CajaSesion @relation(fields: [cajaSesionId], references: [id])
  cajaId                   String
  caja                     Caja       @relation(fields: [cajaId], references: [id])
  userId                   String
  user                     User       @relation(fields: [userId], references: [id])
  efectivoEsperadoCentavos Int
  efectivoContadoCentavos  Int
  diferenciaCentavos       Int        // = contado − esperado
  nota                     String?
  fecha                    DateTime   @default(now())
  organizationId           String
  organization             Organization @relation(fields: [organizationId], references: [id])
}

model MovimientoCaja {
  id              String         @id @default(cuid())
  cajaSesionId    String
  cajaSesion      CajaSesion     @relation(fields: [cajaSesionId], references: [id])
  cajaId          String
  caja            Caja           @relation(fields: [cajaId], references: [id])
  saleId          String?
  sale            Sale?          @relation(fields: [saleId], references: [id])
  tipo            String         // "VENTA" | "INGRESO" | "EGRESO" | "AJUSTE" — validado Zod
  montoCentavos   Int            // porción de esta caja (sin recargo)
  recargoCentavos Int            @default(0) // recargo virtual atribuido a esta caja (Fase 5)
  medioPagoId     String?
  medioPago       PaymentMethod? @relation(fields: [medioPagoId], references: [id])
  nota            String?
  // Liga este EGRESO al gasto fijo que paga (ej. "Alquiler + Gastos") — así el
  // equilibrio de Inicio puede descontar del total a pagar del mes lo que ya
  // salió de caja, en vez de comparar contra el monto bruto configurado.
  fixedExpenseId  String?
  fixedExpense    FixedExpense?  @relation(fields: [fixedExpenseId], references: [id])
  organizationId  String
  organization    Organization   @relation(fields: [organizationId], references: [id])
  fecha           DateTime       @default(now())
}

// ─── Productos y stock ───────────────────────────────────────────────────────

model Product {
  id                 String    @id @default(cuid())
  sku                String
  barcode            String?
  nombre             String
  costoCentavos      Int
  precioCentavos     Int
  costoEsProvisional Boolean   @default(false)
  categoryId         String
  category           Category  @relation(fields: [categoryId], references: [id])
  providerId         String?
  provider           Provider? @relation(fields: [providerId], references: [id])
  locationId         String?
  location           Location? @relation(fields: [locationId], references: [id])
  stock              Int       @default(0)
  stockMinimo        Int       @default(0)
  // ── Pesables (vendidos por peso, ej. fiambre) ────────────────────────────
  // Campos aislados de los de arriba: cuando esPesable=true, costoCentavos/precioCentavos/
  // stock/stockMinimo se IGNORAN — se usan estos en su lugar. Evita mezclar "por unidad" con
  // "por kg" en la misma columna (bug de plata si algún cálculo se olvida de chequear esPesable).
  esPesable          Boolean   @default(false)
  costoPorKgCentavos Int?
  precioPorKgCentavos Int?
  stockGramos        Int?
  stockMinimoGramos  Int?
  // Cigarrillo vendido suelto (no en atado) — recargo distinto al de atados
  // cuando se paga con QR/Posnet (ver domain/recargo-cigarrillos.ts).
  esCigarroSuelto    Boolean   @default(false)
  activo             Boolean   @default(true)
  organizationId     String
  organization       Organization @relation(fields: [organizationId], references: [id])
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  saleLines      SaleLine[]
  stockMovements StockMovement[]

  @@unique([sku, organizationId])
  // NULL barcode no conflicta con otro NULL en PostgreSQL (NULLs != NULLs en unique)
  @@unique([barcode, organizationId])
}

model StockMovement {
  id              String              @id @default(cuid())
  productId       String
  product         Product             @relation(fields: [productId], references: [id])
  userId          String
  user            User                @relation(fields: [userId], references: [id])
  tipo            TipoMovimientoStock
  cantidad        Int
  stockAnterior   Int
  stockPosterior  Int
  // Pesables: gramos en vez de unidades. Nulos cuando el producto no es pesable.
  gramos          Int?
  gramosAnterior  Int?
  gramosPosterior Int?
  motivo          String?
  saleId          String?
  sale            Sale?               @relation(fields: [saleId], references: [id])
  creadoEn        DateTime            @default(now())
}

// ─── Ventas ──────────────────────────────────────────────────────────────────

model Sale {
  id                 String       @id @default(cuid())
  fecha              DateTime     @default(now())
  userId             String
  user               User         @relation(fields: [userId], references: [id])
  totalCentavos      Int
  costoTotalCentavos Int
  recargoCentavos    Int          @default(0) // Fase 5: recargo total por pago virtual
  descuentoCentavos  Int          @default(0) // descuento manual aplicado por el cajero, ya restado de totalCentavos
  // Traspaso de cigarrillos vendidos por QR/Posnet: el proveedor de cigarrillos
  // solo acepta efectivo, así que el monto (0 = no aplica) se calcula al crear
  // la venta pero el movimiento de caja (EGRESO Caja general + INGRESO Caja
  // Cigarrillos) recién se crea cuando alguien confirma que hizo el traspaso
  // físico — ver ventaService.confirmarTraspasoCigarrillos.
  traspasoCigarrillosCentavos   Int     @default(0)
  traspasoCigarrillosConfirmado Boolean @default(false)
  // Consumo de personal o del dueño (no es una venta real a un cliente): se
  // cobra $0 (vía el mismo descuento manual del 100%) pero descuenta stock
  // igual que cualquier venta. Se excluye de las cifras de ganancia y del
  // fondo de reposición por proveedor — ver ventaService.crear.
  esConsumoInterno   Boolean      @default(false)
  // Cuenta corriente: parte del total que quedó fiada a un cliente en vez de
  // cobrada (0 = venta cobrada por completo). Requiere customerId. Nunca se
  // suma a ningún MovimientoCaja — es plata que no entró todavía.
  fiadoCentavos      Int          @default(0)
  customerId         String?
  customer           Customer?    @relation(fields: [customerId], references: [id])
  organizationId     String
  organization       Organization @relation(fields: [organizationId], references: [id])
  createdAt          DateTime     @default(now())

  lines           SaleLine[]
  payments        Payment[]
  stockMovements  StockMovement[]
  movimientosCaja MovimientoCaja[]
  comprobante     Comprobante?
}

model SaleLine {
  id                     String  @id @default(cuid())
  saleId                 String
  sale                   Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId              String
  product                Product @relation(fields: [productId], references: [id])
  cantidad               Int
  // Pesables: gramos vendidos. precioUnitarioCentavos/costoUnitarioCentavos son "por kg" en ese caso.
  // cantidad queda en 1 (una línea = un lote pesado), no se usa para el cálculo de subtotal.
  gramos                 Int?
  precioUnitarioCentavos Int     // foto al momento de la venta — inmutable
  costoUnitarioCentavos  Int     // foto al momento de la venta — inmutable
}

model Payment {
  id                   String        @id @default(cuid())
  saleId               String
  sale                 Sale          @relation(fields: [saleId], references: [id], onDelete: Cascade)
  paymentMethodId      String
  paymentMethod        PaymentMethod @relation(fields: [paymentMethodId], references: [id])
  montoCentavos        Int
  comisionCentavos     Int           // estimada = monto × comisionBp / 10_000
  montoNetoCentavos    Int           // monto − comision
  comisionRealCentavos Int?          // TODO: completar al integrar MercadoPago
  referencia           String?       // mp payment id, transferencia ref, etc.
  createdAt            DateTime      @default(now())
}

// ─── Facturación (AFIP/ARCA) ────────────────────────────────────────────────

/**
 * Comprobante fiscal emitido (o intentado) para una venta — ver
 * facturacionService.facturarVenta y src/lib/providers/facturacion. No toda
 * venta tiene uno: solo se genera si algún medio de pago usado tiene
 * facturarAutomaticamente=true (ver PaymentMethod).
 */
model Comprobante {
  id     String @id @default(cuid())
  saleId String @unique
  sale   Sale   @relation(fields: [saleId], references: [id])

  tipo       String // FACTURA_A | FACTURA_B | FACTURA_C — validado Zod
  puntoVenta Int
  // AFIP asigna el número recién al emitir con éxito — null mientras está
  // PENDIENTE o quedó en ERROR (el reintento vuelve a pedir el próximo número,
  // createNextVoucher evita que dos reintentos se pisen).
  numero              Int?
  cae                 String?
  caeFechaVencimiento DateTime?
  estado              String // PENDIENTE | EMITIDO | ERROR — validado Zod
  error               String? // último mensaje de AFIP, para diagnosticar antes de reintentar

  cuitCliente         String?
  razonSocialCliente  String
  condicionIVACliente String // CondicionIVA de fiscal.ts — validado Zod

  subtotalCentavos Int
  ivaTotalCentavos Int
  totalCentavos    Int

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}
