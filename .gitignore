# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# paquete instalable del kiosco (contiene .env.local con secretos reales)
/dist

# misc
.DS_Store
*.pem
/certs/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# local database (SQLite)
*.db
*.db-journal
*.db-wal

# kiosco (logs del server local)
/logs

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

.vercel

# tooling local del agente (Claude Code) — no va al repo
.claude/
