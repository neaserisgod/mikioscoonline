{
  "name": "pyme-ventas",
  "version": "1.0.2",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:local": "cross-env LOCAL_DEV=1 DATABASE_URL=file:./dev.db next dev",
    "build": "next build",
    "postbuild": "node scripts/prepare-standalone.mjs",
    "build:standalone": "next build --webpack && node scripts/prepare-standalone.mjs",
    "start": "next start",
    "start:local": "node scripts/start-local-server.mjs",
    "lint": "eslint",
    "postinstall": "prisma generate && cross-env LOCAL_DEV=1 prisma generate",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma migrate reset --force && tsx prisma/seed.ts",
    "db:push:local": "cross-env LOCAL_DEV=1 prisma db push",
    "db:seed:local": "cross-env LOCAL_DEV=1 tsx prisma/seed.ts",
    "db:push:kiosco": "cross-env LOCAL_DEV=1 DATABASE_URL=file:./kiosco.db prisma db push",
    "kiosco:download-data": "tsx scripts/kiosco-download-data.ts",
    "kiosco:backup-once": "tsx scripts/kiosco-backup-once.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@hookform/resolvers": "^5.4.0",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@tanstack/query-sync-storage-persister": "^5.101.2",
    "@tanstack/react-query": "^5.101.1",
    "@tanstack/react-query-devtools": "^5.101.1",
    "@tanstack/react-query-persist-client": "^5.101.2",
    "@types/papaparse": "^5.5.2",
    "@types/pg": "^8.20.0",
    "@zxing/browser": "^0.2.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "framer-motion": "^12.42.0",
    "jose": "^6.2.3",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "next-auth": "^5.0.0-beta.31",
    "next-themes": "^0.4.6",
    "papaparse": "^5.5.4",
    "pg": "^8.22.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.80.0",
    "recharts": "^3.9.0",
    "shadcn": "^4.12.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@tauri-apps/cli": "^2.11.4",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "jsdom": "^29.1.1",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
