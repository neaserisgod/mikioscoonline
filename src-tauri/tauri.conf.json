{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "La Plazoleta Soft",
  "version": "1.0.7",
  "identifier": "ar.kioscoelbarrio.pos",
  "build": {
    "frontendDist": "loading-page"
  },
  "app": {
    "windows": [
      {
        "title": "La Plazoleta Soft",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/neaserisgod/mikioscoonline/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDNCQ0E1Q0Q2OEYwNDM5NDEKUldSQk9RU1AxbHpLTy9sS2lKMVZlREU5ZFhPZHEveWZ4Slc2WlUxRCswL2QzeFRUMGhXc3R3aUQK"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "msi",
      "nsis"
    ],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../.next/standalone/": "next-standalone/",
      "resources/dev-template.db": "dev-template.db",
      "resources/migraciones-sqlite/": "migraciones-sqlite/",
      "resources/node/node.exe": "node/node.exe"
    }
  }
}
