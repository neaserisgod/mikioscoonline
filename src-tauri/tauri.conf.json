{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Kiosco El Barrio",
  "version": "0.1.0",
  "identifier": "ar.kioscoelbarrio.pos",
  "build": {
    "frontendDist": "loading-page"
  },
  "app": {
    "windows": [
      {
        "title": "Kiosco El Barrio",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../.next/standalone/": "next-standalone/",
      "resources/dev-template.db": "dev-template.db"
    }
  }
}
