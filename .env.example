# ─── Base de datos ────────────────────────────────────────────────────────────
# PostgreSQL — obtené la string en https://console.neon.tech (Neon)
# Formato: postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=""

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generá con: npx auth secret  (o: openssl rand -base64 32)
AUTH_SECRET=""
# Necesario en Vercel para que NextAuth confíe en el header X-Forwarded-Host
AUTH_TRUST_HOST=true

# ─── Google OAuth (login/registro) ────────────────────────────────────────────
# Credenciales en https://console.cloud.google.com/apis/credentials
# Tipo "Aplicación web". URI de redirección autorizado:
#   https://tu-dominio/api/auth/callback/google
#   http://localhost:3000/api/auth/callback/google (dev)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ─── Seed ─────────────────────────────────────────────────────────────────────
# Email del usuario admin que crea npm run db:seed. Default: admin@kiosco.ar
SEED_ADMIN_EMAIL=""
# Contraseña de ese usuario admin. Obligatoria, sin default.
# Usá algo fuerte: mínimo 12 caracteres, letras + números + símbolos
SEED_ADMIN_PASSWORD=""

# ─── Modo dev local (opcional) ─────────────────────────────────────────────────
# LOCAL_DEV=1: usa prisma/schema.dev.prisma (SQLite) en vez de prisma/schema.prisma (Postgres),
# y la DATABASE_URL de .env en vez de .env.local. Ver prisma.config.ts.
LOCAL_DEV=

# ─── Pagos ────────────────────────────────────────────────────────────────────
# "mock" para desarrollo local; "mercadopago" cuando integres MP real
PAGOS_PROVIDER="mock"

# MercadoPago — necesario cuando PAGOS_PROVIDER="mercadopago"
# Obtené las credenciales en https://www.mercadopago.com.ar/developers
MP_ACCESS_TOKEN=""
MP_PUBLIC_KEY=""
MP_WEBHOOK_SECRET=""

# ─── Suscripción del SaaS (paywall) ────────────────────────────────────────────
# Plata que el kiosco nos paga a nosotros por usar el sistema — usa el mismo
# MP_ACCESS_TOKEN de arriba (misma cuenta). Se crea una única vez con
# crearPreapprovalPlan() en src/lib/mercadopago-suscripcion.ts.
MP_PREAPPROVAL_PLAN_ID=""

# ─── Facturación AFIP/ARCA (vía AfipSDK — https://afipsdk.com) ─────────────────
# "mock" para desarrollo local; "afip" cuando conectes el SDK real (ver README)
FACTURACION_PROVIDER="mock"

# AFIP/ARCA — necesario cuando FACTURACION_PROVIDER="afip"
# access_token: sacar gratis en https://app.afipsdk.com
# Sin AFIP_CERT/AFIP_PRIVATE_KEY: usa el CUIT de prueba de AfipSDK (20409378472),
# siempre homologación. Con cert+key (CUIT real, portal ARCA con Clave Fiscal):
# el switch homologación/producción se maneja por organización, desde la app
# (Config > Negocio > "Facturación AFIP en modo producción"), no acá.
AFIP_ACCESS_TOKEN=""
AFIP_CUIT="20409378472"
AFIP_CERT=""
AFIP_PRIVATE_KEY=""
